# Server
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio notifications
# Use whatsapp for WhatsApp notifications or sms for regular text messages.
# For Twilio WhatsApp sandbox, +14155238886 is the sender/from number.
# NOTIFY_TO_NUMBER is the WhatsApp phone that receives order notifications.
NOTIFY_CHANNEL=whatsapp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_FROM_NUMBER=+15551234567
NOTIFY_TO_NUMBER=+254746601060

# Human transfer destination
# Must be E.164 format, including the leading + and country code.
HUMAN_TRANSFER_NUMBER=+254746601060
