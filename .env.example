# Server
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio notifications
# Use whatsapp for WhatsApp notifications or sms for regular text messages.
# For Twilio WhatsApp sandbox, +14155238886 is the sender/from number.
# NOTIFY_TO_NUMBER is the WhatsApp phone that receives order notifications.
NOTIFY_CHANNEL=whatsapp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_FROM_NUMBER=+15551234567
NOTIFY_TO_NUMBER=+254746601060

# Human transfer destination
# Must be E.164 format, including the leading + and country code.
HUMAN_TRANSFER_NUMBER=+254746601060

# SaaS platform settings
APP_BASE_URL=https://yourdomain.com
APP_ENCRYPTION_KEY=replace-with-32-byte-random-secret
DEFAULT_CURRENCY=KES
DEFAULT_COUNTRY_CODE=KE
DEFAULT_TIMEZONE=Africa/Nairobi
DEFAULT_AI_CALL_PRICE_PER_MINUTE=20
LOW_BALANCE_THRESHOLD=300
URGENT_BALANCE_THRESHOLD=100

# Hidden provider credentials for future SaaS mode
VAPI_API_KEY=your-vapi-api-key
AFRICASTALKING_USERNAME=your-africastalking-username
AFRICASTALKING_API_KEY=your-africastalking-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# M-Pesa / payments provider placeholders
MPESA_PROVIDER=africastalking
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
